# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_REDDIT_URL=

# Get this from your project's API settings (service_role key)
SUPABASE_SERVICE_ROLE_KEY=

# Use a stable key per app when multiple projects share one Supabase instance
APP_KEY=seeddance2
NEXT_PUBLIC_APP_KEY=seeddance2

# Creem.io Payment Configuration
CREEM_WEBHOOK_SECRET=
CREEM_API_KEY=
CREEM_API_URL=https://test-api.creem.io/v1

# Site URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Seedance 2.0
NEXT_PUBLIC_OG_IMAGE_PATH=/web-app-manifest-512x512.png
NEXT_PUBLIC_SUPPORT_EMAIL=hello@seedance2video.cc
BASE_URL=localhost:3000

# Redirect success url after payment
CREEM_SUCCESS_URL=http://localhost:3000/dashboard

# AI Configuration
# Get your API key from OpenRouter (https://openrouter.ai/)
# Optional if you route video or multimodal tasks through an OpenAI-compatible provider
OPENROUTER_API_KEY=

# Optional: OpenAI compatible endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Replicate Configuration (legacy, optional)
REPLICATE_API_TOKEN=

# Kie AI Seedance configuration
KIE_API_KEY=
KIE_API_URL=https://api.kie.ai/api/v1
KIE_CALLBACK_SECRET=

# Doubao TTS Configuration for Voice Playback
# Get these from Doubao/ByteDance TTS service
DOUBAO_TTS_APPID=
DOUBAO_TTS_ACCESS_TOKEN=

# Production Configuration (uncomment for production)
# CREEM_API_URL=https://api.creem.io
# NEXT_PUBLIC_SITE_URL=https://seedance2video.cc
# NEXT_PUBLIC_APP_URL=https://seedance2video.cc
# CREEM_SUCCESS_URL=https://seedance2video.cc/dashboard
